{
  "name": "@hmcs/settings",
  "version": "0.1.0-alpha.6",
  "description": "Application settings mod — provides a tray menu to open the settings panel",
  "license": "MIT",
  "type": "module",
  "author": "notelm",
  "scripts": {
    "build": "pnpm exec vite build ui",
    "dev": "pnpm exec vite dev ui"
  },
  "homunculus": {
    "tray": {
      "id": "open-settings",
      "text": "Settings",
      "command": "settings-open-ui",
      "position": "top"
    },
    "assets": {
      "settings:ui": {
        "path": "ui/dist/index.html",
        "type": "html",
        "description": "Application settings panel UI"
      }
    }
  },
  "bin": {
    "settings-open-ui": "commands/open-ui.ts"
  },
  "dependencies": {
    "@hmcs/sdk": "workspace:*",
    "@hmcs/ui": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/node": "^25.3.3",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react-swc": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vite-plugin-singlefile": "catalog:"
  }
}
