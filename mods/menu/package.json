{
  "name": "@hmcs/menu",
  "version": "0.1.0-alpha.6-dev",
  "description": "Right-click context menu mod that provides a WebView-based HUD overlay for quick in-app actions",
  "license": "MIT",
  "type": "module",
  "author": "notelm",
  "scripts": {
    "build": "pnpm exec vite build ui",
    "dev": "pnpm exec vite dev ui",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build"
  },
  "homunculus": {
    "service": "service.ts",
    "assets": {
      "menu:ui": {
        "path": "ui/dist/index.html",
        "type": "html",
        "description": "Menu HUD UI"
      }
    }
  },
  "dependencies": {
    "@hmcs/sdk": "workspace:*",
    "@hmcs/ui": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "eventsource": "catalog:"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.2.14",
    "@tailwindcss/vite": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react-swc": "catalog:",
    "storybook": "^10.2.14",
    "tailwindcss": "catalog:",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vite-plugin-singlefile": "catalog:"
  }
}
