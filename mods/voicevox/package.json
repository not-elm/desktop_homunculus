{
  "name": "@hmcs/voicevox",
  "version": "0.1.0-alpha.6-dev",
  "author": "notelm",
  "license": "MIT",
  "description": "VoiceVox TTS integration for Desktop Homunculus",
  "type": "module",
  "scripts": {
    "build": "pnpm exec vite build ui",
    "dev": "pnpm exec vite dev ui"
  },
  "bin": {
    "voicevox-open-settings": "commands/open-settings.ts"
  },
  "homunculus": {
    "service": "service.ts",
    "menus": [
      {
        "id": "open-voicevox-settings",
        "text": "VOICEVOX",
        "command": "voicevox-open-settings"
      }
    ],
    "assets": {
      "voicevox:ui": {
        "path": "ui/dist/index.html",
        "type": "html",
        "description": "VOICEVOX character voice settings UI"
      }
    }
  },
  "dependencies": {
    "@hmcs/sdk": "workspace:*",
    "@hmcs/ui": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/node": "^25.3.3",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react-swc": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vite-plugin-singlefile": "catalog:"
  }
}
