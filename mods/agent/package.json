{
  "name": "@hmcs/agent",
  "version": "0.1.0-alpha.6-dev",
  "description": "AI agent integration for Desktop Homunculus characters",
  "license": "MIT",
  "author": "notelm",
  "type": "module",
  "scripts": {
    "build": "pnpm exec vite build ui/session",
    "dev": "pnpm exec vite dev ui/session",
    "test": "vitest run"
  },
  "homunculus": {
    "service": "service.ts",
    "menus": [
      {
        "id": "open-agent",
        "text": "Agent",
        "command": "agent-open-agent"
      }
    ],
    "assets": {
      "agent:session-ui": {
        "path": "ui/session/dist/index.html",
        "type": "html",
        "description": "Agent session HUD"
      },
      "agent:request-permissions": {
        "path": "assets/request_permissions.mp3",
        "type": "sound",
        "description": "Permission request SE"
      }
    }
  },
  "bin": {
    "agent-open-agent": "commands/open-agent.ts",
    "agent-start-session": "commands/start-session.ts",
    "agent-stop-session": "commands/stop-session.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@hmcs/sdk": "workspace:*",
    "@hmcs/ui": "workspace:*",
    "@openai/codex": "^0.117.0",
    "lucide-react": "^0.525.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "uiohook-napi": "^1.5.4",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@types/node": "^25.3.3",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react-swc": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vite-plugin-singlefile": "catalog:",
    "vitest": "^3.2.3"
  }
}
