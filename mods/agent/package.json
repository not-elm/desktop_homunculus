{
  "name": "@hmcs/agent",
  "version": "0.1.0-alpha.6-dev",
  "description": "AI agent integration for Desktop Homunculus characters",
  "license": "MIT",
  "author": "notelm",
  "type": "module",
  "scripts": {
    "build": "pnpm exec vite build ui/settings && pnpm exec vite build ui/session",
    "dev": "concurrently \"pnpm exec vite dev ui/settings\" \"pnpm exec vite dev ui/session\""
  },
  "homunculus": {
    "service": "service.ts",
    "menus": [
      {
        "id": "open-agent-settings",
        "text": "Agent Settings",
        "command": "agent-open-settings"
      },
      {
        "id": "start-agent-session",
        "text": "会話を開始",
        "command": "agent-start-session"
      },
      {
        "id": "stop-agent-session",
        "text": "会話を終了",
        "command": "agent-stop-session"
      }
    ],
    "assets": {
      "agent:settings-ui": {
        "path": "ui/settings/dist/index.html",
        "type": "html",
        "description": "Agent settings panel"
      },
      "agent:session-ui": {
        "path": "ui/session/dist/index.html",
        "type": "html",
        "description": "Agent session HUD"
      }
    }
  },
  "bin": {
    "agent-open-settings": "commands/open-settings.ts",
    "agent-start-session": "commands/start-session.ts",
    "agent-stop-session": "commands/stop-session.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@hmcs/sdk": "workspace:*",
    "@hmcs/ui": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "uiohook-napi": "^1.5.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "concurrently": "^9",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
