{
  "name": "@hmcs/nav-test",
  "version": "0.1.0-alpha.6-dev",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "pnpm exec vite build ui",
    "dev": "pnpm exec vite dev ui"
  },
  "homunculus": {
    "menus": [
      {
        "id": "open-nav-test",
        "text": "Nav Test",
