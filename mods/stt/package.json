{
  "name": "@hmcs/stt",
  "version": "0.1.0-alpha.6-dev",
  "description": "Speech-to-Text control panel — provides a tray menu to manage STT models and sessions",
  "license": "MIT",
  "type": "module",
  "author": "notelm",
  "scripts": {
    "build": "pnpm exec vite build ui",
    "dev": "pnpm exec vite dev ui"
  },
  "homunculus": {
    "tray": {
      "id": "open-stt",
      "text": "Speech to Text",
      "command": "stt-open-ui"
    },
    "assets": {
      "stt:ui": {
        "path": "ui/dist/index.html",
        "type": "html",
        "description": "Speech-to-Text control panel UI"
      }
    }
  },
  "bin": {
    "stt-open-ui": "commands/open-ui.ts"
  },
  "dependencies": {
    "@hmcs/sdk": "workspace:*",
    "@hmcs/ui": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
