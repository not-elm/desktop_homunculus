{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "ui/dist/**", "ui/*/dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "check-types": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "docs#build": {
      "outputs": ["build/**"]
    },
    "docs#dev": {
      "cache": false,
      "persistent": true
    }
  }
}
