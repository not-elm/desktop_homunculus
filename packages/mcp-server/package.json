{
  "name": "@hmcs/mcp-server",
  "version": "0.1.0",
  "license": "MIT",
  "description": "MCP server for Desktop Homunculus — exposes desktop mascot character control to AI agents via Model Context Protocol",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "homunculus-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@hmcs/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
