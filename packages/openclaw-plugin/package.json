{
  "name": "@hmcs/openclaw-plugin",
  "version": "0.1.0-alpha.6",
  "type": "module",
  "main": "./dist/entry.js",
  "license": "MIT",
  "author": "notelm",
  "description": "OpenClaw plugin bridging agent output to Desktop Homunculus characters.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/not-elm/desktop-homunculus.git",
    "directory": "packages/openclaw-plugin"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "rimraf dist && esbuild src/entry.ts --bundle --platform=node --format=esm --outfile=dist/entry.js --external:openclaw --external:openclaw/*",
    "dev": "esbuild src/entry.ts --bundle --platform=node --format=esm --outfile=dist/entry.js --external:openclaw --external:openclaw/* --watch",
    "test": "vitest run",
    "check-types": "tsc -p tsconfig.json --noEmit"
  },
  "openclaw": {
    "extensions": [
      "./dist/entry.js"
    ]
  },
  "devDependencies": {
    "@hmcs/sdk": "workspace:*",
    "esbuild": "^0.24.0",
    "eventsource": "catalog:",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "vitest": "^3.2.3"
  },
  "peerDependencies": {
    "openclaw": "*"
  }
}
