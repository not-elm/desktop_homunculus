#!/usr/bin/env node

"use strict";

const { execFileSync } = require("child_process");
const path = require("path");

const PLATFORM_MAP = {
  "darwin-arm64": "@hmcs/cli-darwin-arm64",
  "darwin-x64": "@hmcs/cli-darwin-x64",
  "win32-x64": "@hmcs/cli-win32-x64",
};

const platformKey = `${process.platform}-${process.arch}`;
const pkg = PLATFORM_MAP[platformKey];

if (!pkg) {
  console.error(
    `Error: Unsupported platform ${platformKey}.\n` +
      `@hmcs/cli currently supports: ${Object.keys(PLATFORM_MAP).join(", ")}`
  );
  process.exit(1);
}

const exe = process.platform === "win32" ? "hmcs.exe" : "hmcs";

let binaryPath;
try {
  binaryPath = path.join(
    path.dirname(require.resolve(`${pkg}/package.json`)),
    exe
  );
} catch {
  console.error(
    `Error: Could not find the hmcs binary for ${platformKey}.\n` +
      `The platform package ${pkg} may not be installed.\n` +
      `Try reinstalling: npm install -g @hmcs/cli`
  );
  process.exit(1);
}

try {
  execFileSync(binaryPath, process.argv.slice(2), { stdio: "inherit" });
} catch (e) {
  process.exitCode = e.status ?? 1;
}
